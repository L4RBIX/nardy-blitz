# ── Supabase (optional — multiplayer + leaderboard) ──────────────────────────
# Create a project at https://supabase.com, run supabase/schema.sql,
# then paste your project URL and anon key here.
# Without these vars the app still works — multiplayer/leaderboard show setup states.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── AI Coach backend (optional) ───────────────────────────────────────────────
# FastAPI backend for ML-style game analysis.
# Without this the app falls back to the local rule-based coach automatically.
# Copy to .env.local and start the backend with:
#   cd backend && python3 -m uvicorn main:app --reload --port 8000

NEXT_PUBLIC_COACH_API_URL=http://localhost:8000/api/analyze-game
